#!/bin/sh
# postinst — Runs after installing the Vault package
set -e

# Updates the GTK/hicolor icon cache so the new icon appears in the
# application launcher, dock, and system menus.
if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    gtk-update-icon-cache -f -t /usr/share/icons/hicolor || true
fi

# Refreshes the desktop application database (GNOME/KDE/XFCE)
if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database -q /usr/share/applications || true
fi

# Refreshes the MIME types database
if command -v update-mime-database >/dev/null 2>&1; then
    update-mime-database /usr/share/mime || true
fi

exit 0
