{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "boveda",
  "version": "1.0.0",
  "identifier": "com.boveda.password-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Bóveda — Gestor de Credenciales",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 800,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
