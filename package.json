{
  "name": "boveda",
  "version": "1.0.0",
  "description": "Password Manager.",
  "status": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "audit:rust": "cargo audit",
    "audit:js": "pnpm audit",
    "security": "pnpm run audit:js && pnpm run audit:rust",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "preinstall": "node -e \"if (process.env.npm_execpath && !process.env.npm_execpath.includes('pnpm')) { console.error('\\x1b[31m[ERROR] Bóveda requiere usar pnpm. Ejecutar npm install está deshabilitado por seguridad.\\x1b[0m\\n'); process.exit(1); }\""
  },
  "license": "AGPL-3.0",
