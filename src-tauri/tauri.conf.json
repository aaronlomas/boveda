{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Boveda",
  "version": "1.2.0",
  "identifier": "com.boveda.password-manager",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm svelte-kit sync && pnpm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Bóveda — Gestor de Credenciales",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["bvda"],
        "name": "Bóveda Vault",
        "description": "Bóveda encrypted database file",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/aaronlomas/boveda/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1MkY4NjEyQzE3REMzNDAKUldSQXczM0JFb1l2MVRGcUlLaTdiRUs4NGVtYWtmKy9Ma0ZPTlVWTFpPT1ZGWGtrVzVxV0UyZWIK"
    }
  }
}
